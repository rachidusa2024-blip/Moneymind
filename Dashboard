  document.getElementById('daysToPayday').textContent = '5';
  document.getElementById('dailyBudget').textContent = '$44 daily budget';
  document.getElementById('pdDaysBig').textContent = '5';
  document.getElementById('pdBudgetText').textContent = '$44.00 daily budget remaining';
  document.getElementById('pdFill').style.width = '58%';
  document.getElementById('tpDay').textContent = 'Day 0 of 90 — Start your transformation';
  document.getElementById('tpPct').textContent = '0%';
  document.getElementById('tpFill').style.width = '0%';

  if (!userProfile?.onboarding_completed) {
    addDashMsg('bot', "Welcome to Sum Goals! I'm Maya — let's personalize your experience. <strong>What currency do you use and what's your biggest financial challenge right now?</strong>");
  }
}

function showSection(id) {
  document.querySelectorAll('[id^="sec-"]').forEach(s => s.style.display = 'none');
  document.getElementById('sec-' + id).style.display = 'block';
  document.querySelectorAll('.sb-link').forEach(l => l.classList.remove('active'));
}

function showProFeature(feature) {
  const isPro = userProfile?.plan === 'pro' || userProfile?.plan === 'lifetime';
  if (isPro) {
    showSection('maya');
    setDashMode(feature, null);
  } else {
    document.getElementById('promoTitle').textContent = feature.charAt(0).toUpperCase() + feature.slice(1).replace(/([A-Z])/g,' $1');
    showSection('promo');
  }
}

async function handleUpgrade(plan) {
  const { data: { session } } = await sb.auth.getSession();
        window.location.href = '/index.html';
  try {
    const res = await fetch('/api/create-checkout', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${session.access_token}` },
      body: JSON.stringify({ plan })
    });
    const data = await res.json();
    if (data.url) window.location.href = data.url;
    else alert('Something went wrong. Please try again.');
  } catch(e) { alert('Connection error. Please try again.'); }
}

async function handleSignOut() {
  await sb.auth.signOut();
        window.location.href = '/index.html';
}

function setDashMode(mode, btn) {
  dashMode = mode;
  dashHistory = [];
  if (btn) {
    btn.closest('.maya-modes').querySelectorAll('.mmode').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
  }
  const welcomes = {
    coach: "Hey — what do you need help with today? Tell me your currency.",
    budget: "Let's build your budget. <strong>What's your monthly income after taxes? Currency?</strong>",
    payday: "Payday Countdown. <strong>How many days until payday? Current balance? Currency?</strong>",
    debt: "<strong>Tell me all your debts</strong> — name, balance, interest rate. Currency?",
    score: "Health Score check. <strong>Income, expenses, total debt, savings, currency?</strong>",
    personality: "Money Personality Quiz! Ready? <strong>When you get paid, what's the first thing you do?</strong>",
    hustle: "Side Hustle Tracker. <strong>Tell me all your income sources and currency.</strong>",
    emergency: "Emergency Kit. <strong>What type of crisis — job loss, medical bill, or other?</strong>",
    survival: "Survival Mode. <strong>How much money do you have right now and how many days until payday?</strong>",
    transformation: "Your 90-Day Transformation. <strong>Tell me your income, biggest challenge, and currency to start.</strong>",
    mirror: "The Money Mirror. <strong>Tell me: what do you spend most money on, and your last impulse purchase?</strong>",
    couples: "Couples Mode. <strong>Tell me both your incomes and biggest shared financial challenge.</strong>",
    senior: "Senior Mode. <strong>Tell me about your fixed income and currency.</strong>"
  };
  addDashMsg('bot', welcomes[mode] || welcomes.coach);
}

function addDashMsg(role, html, msgsId = 'dashMsgs') {
  const c = document.getElementById(msgsId);
  if (!c) return;
  const row = document.createElement('div');
  row.className = 'mmrow ' + (role === 'bot' ? 'bot' : 'usr');
  const sender = document.createElement('div');
  sender.className = 'mm-sender';
  sender.textContent = role === 'bot' ? 'Maya' : 'You';
  const bub = document.createElement('div');
  bub.className = 'mm-bub';
  bub.innerHTML = fmtMsg(html);
  row.appendChild(sender);
  row.appendChild(bub);
  c.appendChild(row);
  c.scrollTop = c.scrollHeight;
  return bub;
}

function fmtMsg(t) {
  return t.replace(/#{1,3}\s+/g,'').replace(/\*\*(.*?)\*\*/g,'<strong>$1</strong>').replace(/\n\n/g,'<br><br>').replace(/\n/g,'<br>').replace(/[^\x00-\x7F]/g,'');
}

async function sendDash() {
  const inp = document.getElementById('dashInp');
  const text = inp.value.trim();
  if (!text) return;
  const isPro = userProfile?.plan === 'pro' || userProfile?.plan === 'lifetime';
  if (!isPro && sessionCount >= FREE_LIMIT) {
    addDashMsg('bot', "You've used your <strong>5 free sessions</strong> today. Upgrade to Pro for unlimited coaching with Maya.");
    return;
  }
  inp.value = '';
  document.getElementById('dashSend').disabled = true;
  addDashMsg('usr', text);
  dashHistory.push({ role: 'user', content: text });
  sessionCount++;
  const typing = addDashMsg('bot', '<div class="typing"><div class="tdot"></div><div class="tdot"></div><div class="tdot"></div></div>');
  try {
    const { data: { session } } = await sb.auth.getSession();
    const res = await fetch('/api/chat', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${session?.access_token || ''}` },
      body: JSON.stringify({ messages: dashHistory, mode: dashMode })
    });
    const data = await res.json();
    if (typing) { typing.innerHTML = fmtMsg(data.reply || 'Something went wrong.'); }
    if (data.reply) dashHistory.push({ role: 'assistant', content: data.reply });
  } catch(e) {
    if (typing) typing.textContent = 'Connection error. Please try again.';
  }
  document.getElementById('dashSend').disabled = false;
}

