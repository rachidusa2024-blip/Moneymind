let specialHistories = {};
async function sendSpecific(mode, inpId, msgsId) {
  const inp = document.getElementById(inpId);
  const text = inp.value.trim();
  if (!text) return;
  inp.value = '';
  if (!specialHistories[mode]) specialHistories[mode] = [];
  addDashMsg('usr', text, msgsId);
  specialHistories[mode].push({ role: 'user', content: text });
  const typing = addDashMsg('bot', '<div class="typing"><div class="tdot"></div><div class="tdot"></div><div class="tdot"></div></div>', msgsId);
  try {
    const { data: { session } } = await sb.auth.getSession();
    const res = await fetch('/api/chat', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${session?.access_token || ''}` },
      body: JSON.stringify({ messages: specialHistories[mode], mode })
    });
    const data = await res.json();
    if (typing) typing.innerHTML = fmtMsg(data.reply || 'Something went wrong.');
    if (data.reply) specialHistories[mode].push({ role: 'assistant', content: data.reply });
  } catch(e) {
    if (typing) typing.textContent = 'Connection error.';
  }
}

function setupPayday() {
