const { createClient } = supabase;
const sb = createClient(SUPABASE_URL, SUPABASE_ANON_KEY);

let currentUser = null;
let userProfile = null;
let dashMode = 'coach';
let dashHistory = [];
let dashHistory2 = [];
let sessionCount = 0;
const FREE_LIMIT = 5;

// INIT
async function init() {
  const { data: { session } } = await sb.auth.getSession();
        window.location.href = '/index.html';
  currentUser = session.user;
  await loadProfile();
  setupUI();
  document.getElementById('loadingScreen').style.display = 'none';
  document.getElementById('appLayout').style.display = 'flex';
}

async function loadProfile() {
  const { data } = await sb.from('profiles').select('*').eq('id', currentUser.id).single()
    .catch(() => ({ data: null }));
  if (!data) {
    userProfile = { full_name: currentUser.user_metadata?.full_name || currentUser.email.split('@')[0], plan: 'free', currency: 'USD' };
  } else {
    userProfile = data;
  }
}

function setupUI() {
  const name = userProfile?.full_name || currentUser.email.split('@')[0];
  const initials = name.split(' ').map(n => n[0]).join('').toUpperCase().slice(0,2);
  document.getElementById('sbAv').textContent = initials;
  document.getElementById('sbName').textContent = name;
  document.getElementById('userName').textContent = name.split(' ')[0];

  const plan = userProfile?.plan || 'free';
  const planEl = document.getElementById('sbPlan');
  planEl.textContent = plan.charAt(0).toUpperCase() + plan.slice(1);
  planEl.className = 'sb-plan ' + plan;

  if (plan === 'free') {
    document.getElementById('sidebarUpgradeBtn').style.display = 'block';
  }

  const hr = new Date().getHours();
  document.getElementById('greeting').textContent = hr < 12 ? 'morning' : hr < 17 ? 'afternoon' : 'evening';

  document.getElementById('healthScore').textContent = '74';
  document.getElementById('scoreCircle').textContent = '74';
