<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>My Dashboard — Sum Goals</title>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=Playfair+Display:ital,wght@0,700;1,700&display=swap" rel="stylesheet">
<script src="https://unpkg.com/@supabase/supabase-js@2"></script>
<style>
:root{
  --bg:#060D16;--bg2:#08111C;--bg3:#0C1A28;--card:#0F2035;--card2:#132540;
  --teal:#00C9A7;--teal-dark:#00A888;--teal-dim:rgba(0,201,167,0.1);--teal-border:rgba(0,201,167,0.2);
  --gold:#FFB347;--gold-dim:rgba(255,179,71,0.1);--gold-border:rgba(255,179,71,0.2);
  --white:#E8F4F8;--muted:#7AA8C0;--dim:#2A4A62;--border:rgba(255,255,255,0.07);
  --red:#FF6B6B;--green:#4CAF82;
  --font-head:'Playfair Display',serif;--font-body:'Plus Jakarta Sans',sans-serif;
}
*{margin:0;padding:0;box-sizing:border-box}
body{background:var(--bg);color:var(--white);font-family:var(--font-body);font-size:15px;min-height:100vh}
@keyframes up{from{opacity:0;transform:translateY(16px)}to{opacity:1;transform:translateY(0)}}
@keyframes spin{to{transform:rotate(360deg)}}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.4}}
.spinner{width:20px;height:20px;border:2px solid rgba(255,255,255,.2);border-top-color:var(--teal);border-radius:50%;animation:spin .6s linear infinite;margin:0 auto}

/* SIDEBAR */
.layout{display:flex;min-height:100vh}
.sidebar{width:240px;background:var(--bg2);border-right:1px solid var(--border);display:flex;flex-direction:column;position:fixed;top:0;left:0;height:100vh;z-index:10;flex-shrink:0}
.sb-logo{padding:20px 20px 14px;border-bottom:1px solid var(--border)}
.logo{font-family:var(--font-head);font-size:20px;font-style:italic;color:var(--white)}.logo span{color:var(--teal)}
.sb-user{padding:14px 16px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:10px}
.sb-av{width:34px;height:34px;border-radius:50%;background:var(--teal);display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:700;color:#060D16;flex-shrink:0}
.sb-name{font-size:13px;font-weight:600;color:var(--white)}
.sb-plan{font-size:10px;font-weight:700;padding:1px 7px;border-radius:3px;display:inline-block;margin-top:2px}
.sb-plan.free{background:var(--dim);color:var(--muted)}
.sb-plan.pro{background:var(--teal-dim);color:var(--teal);border:1px solid var(--teal-border)}
.sb-plan.lifetime{background:var(--gold-dim);color:var(--gold);border:1px solid var(--gold-border)}
.sb-nav{flex:1;padding:12px 10px;overflow-y:auto}
.sb-section{font-size:10px;font-weight:700;color:var(--dim);text-transform:uppercase;letter-spacing:.1em;padding:10px 8px 6px;margin-top:4px}
.sb-link{display:flex;align-items:center;gap:10px;padding:9px 10px;border-radius:8px;color:var(--muted);font-size:13px;font-weight:500;cursor:pointer;transition:all .2s;border:none;background:transparent;width:100%;text-align:left;font-family:var(--font-body)}
.sb-link:hover{background:var(--card);color:var(--white)}
.sb-link.active{background:var(--teal-dim);color:var(--teal);border:1px solid var(--teal-border)}
.sb-link-icon{width:18px;height:18px;border-radius:4px;background:currentColor;opacity:.3;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:700}
.sb-link.active .sb-link-icon{opacity:1}
.sb-bottom{padding:12px 10px;border-top:1px solid var(--border)}
.btn-upgrade{width:100%;padding:10px;background:var(--teal);color:#060D16;border:none;border-radius:8px;font-weight:700;font-size:13px;cursor:pointer;font-family:var(--font-body);transition:all .2s;margin-bottom:8px}
.btn-upgrade:hover{background:var(--teal-dark)}
.btn-signout{width:100%;padding:8px;background:transparent;color:var(--muted);border:1px solid var(--border);border-radius:8px;font-size:12px;cursor:pointer;font-family:var(--font-body);transition:all .2s}
.btn-signout:hover{color:var(--white);border-color:rgba(255,255,255,.2)}

/* MAIN */
.main{flex:1;margin-left:240px;padding:28px;min-height:100vh}
.page-header{margin-bottom:24px;opacity:0;animation:up .5s ease forwards}
.page-title{font-family:var(--font-head);font-size:28px;font-style:italic;margin-bottom:4px}
.page-sub{font-size:13px;color:var(--muted)}

/* STATS ROW */
.stats-row{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:20px;opacity:0;animation:up .5s ease .1s forwards}
.stat-card{background:var(--card);border:1px solid var(--border);border-radius:12px;padding:16px}
.stat-card.highlight{border-color:var(--teal-border)}
.sc-lbl{font-size:10px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.08em;margin-bottom:8px}
.sc-val{font-family:var(--font-head);font-size:32px;font-style:italic;line-height:1;margin-bottom:4px}
.sc-val.teal{color:var(--teal)}.sc-val.green{color:var(--green)}.sc-val.red{color:var(--red)}.sc-val.gold{color:var(--gold)}
.sc-change{font-size:11px;font-weight:600;display:flex;align-items:center;gap:4px}
.sc-change.up{color:var(--green)}.sc-change.down{color:var(--red)}

/* MAIN GRID */
.dash-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:16px;opacity:0;animation:up .5s ease .2s forwards}
.card{background:var(--card);border:1px solid var(--border);border-radius:14px;padding:20px}
.card.full{grid-column:span 2}
.card-head{display:flex;align-items:center;justify-content:space-between;margin-bottom:16px}
.card-title{font-size:14px;font-weight:700;color:var(--white)}
.card-action{font-size:12px;color:var(--teal);cursor:pointer;border:none;background:transparent;font-family:var(--font-body);font-weight:600}
.card-action:hover{text-decoration:underline}

/* SCORE */
.score-display{display:flex;align-items:center;gap:20px}
.score-circle{width:80px;height:80px;border-radius:50%;border:3px solid var(--teal-border);display:flex;align-items:center;justify-content:center;position:relative;flex-shrink:0}
.score-circle-val{font-family:var(--font-head);font-size:28px;font-style:italic;color:var(--teal)}
.score-details{flex:1}
.score-bar-row{display:flex;align-items:center;gap:8px;margin-bottom:6px;font-size:12px}
.score-bar-label{color:var(--muted);width:80px;flex-shrink:0}
.score-bar-track{flex:1;height:5px;background:var(--bg3);border-radius:3px;overflow:hidden}
.score-bar-fill{height:5px;background:var(--teal);border-radius:3px;transition:width .8s ease}
.score-bar-val{color:var(--teal);font-weight:700;width:28px;text-align:right;flex-shrink:0}

/* PAYDAY */
.payday-big{text-align:center;padding:10px 0}
.pd-days-big{font-family:var(--font-head);font-size:64px;font-style:italic;color:var(--gold);line-height:1}
.pd-label{font-size:11px;color:var(--muted);font-weight:700;text-transform:uppercase;letter-spacing:.1em;margin-bottom:4px}
.pd-budget{font-size:14px;color:var(--white);font-weight:600;margin-top:8px}
.pd-track{height:6px;background:var(--bg3);border-radius:3px;margin-top:12px}
.pd-fill{height:6px;background:var(--gold);border-radius:3px}

/* TRANSFORMATION */
.transform-progress{margin-bottom:12px}
.tp-top{display:flex;justify-content:space-between;align-items:center;margin-bottom:8px}
.tp-day{font-size:12px;color:var(--muted)}
.tp-pct{font-size:13px;font-weight:700;color:var(--teal)}
.tp-track{height:8px;background:var(--bg3);border-radius:4px;overflow:hidden}
.tp-fill{height:8px;background:linear-gradient(90deg,var(--teal),var(--green));border-radius:4px;transition:width 1s ease}
.tp-milestones{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-top:14px}
.milestone{background:var(--bg3);border-radius:8px;padding:10px;text-align:center;border:1px solid var(--border)}
.milestone.done{border-color:var(--teal-border);background:var(--teal-dim)}
.ms-title{font-size:11px;font-weight:600;color:var(--white);margin-bottom:2px}
.ms-sub{font-size:10px;color:var(--muted)}
.ms-check{font-size:14px;margin-bottom:4px}

/* DEBT RACE */
.debt-list{display:flex;flex-direction:column;gap:10px}
.debt-item{background:var(--bg3);border-radius:8px;padding:12px;border:1px solid var(--border)}
.debt-top{display:flex;justify-content:space-between;align-items:center;margin-bottom:8px}
.debt-name{font-size:13px;font-weight:600;color:var(--white)}
.debt-amount{font-size:13px;font-weight:700;color:var(--red)}
.debt-track{height:8px;background:var(--bg);border-radius:4px;overflow:hidden}
.debt-fill{height:8px;border-radius:4px}
.debt-meta{display:flex;justify-content:space-between;margin-top:6px;font-size:10px;color:var(--muted)}

/* MAYA CHAT IN DASHBOARD */
.maya-dash{display:flex;flex-direction:column;height:320px}
.maya-modes{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:12px}
.mmode{background:transparent;border:1px solid var(--border);color:var(--muted);padding:4px 10px;border-radius:14px;font-size:10px;font-weight:600;cursor:pointer;font-family:var(--font-body);transition:all .2s;white-space:nowrap}
.mmode:hover{border-color:var(--teal-border);color:var(--teal)}
.mmode.active{background:var(--teal-dim);border-color:var(--teal-border);color:var(--teal)}
.maya-msgs{flex:1;overflow-y:auto;display:flex;flex-direction:column;gap:10px;margin-bottom:10px;padding-right:4px}
.maya-msgs::-webkit-scrollbar{width:3px}.maya-msgs::-webkit-scrollbar-thumb{background:var(--border);border-radius:2px}
.mmrow{display:flex;flex-direction:column}
.mmrow.bot{align-items:flex-start}.mmrow.usr{align-items:flex-end}
.mm-sender{font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;margin-bottom:3px;padding:0 2px}
.mmrow.bot .mm-sender{color:var(--teal)}.mmrow.usr .mm-sender{color:var(--muted)}
.mm-bub{padding:9px 12px;border-radius:10px;font-size:13px;line-height:1.6;max-width:90%}
.mmrow.bot .mm-bub{background:var(--bg3);border:1px solid var(--border);color:var(--white);border-radius:4px 10px 10px 10px}
.mmrow.usr .mm-bub{background:rgba(0,201,167,.08);border:1px solid rgba(0,201,167,.15);color:var(--white);border-radius:10px 4px 10px 10px}
.mm-bub strong{color:var(--teal)}
.maya-inp-row{display:flex;gap:8px}
.maya-inp{flex:1;background:var(--bg3);border:1px solid var(--border);border-radius:8px;padding:9px 12px;color:var(--white);font-size:13px;font-family:var(--font-body);outline:none}
.maya-inp:focus{border-color:var(--teal-border)}
.maya-inp::placeholder{color:var(--dim)}
.maya-send{background:var(--teal);border:none;border-radius:8px;padding:9px 16px;cursor:pointer;color:#060D16;font-weight:700;font-size:12px;font-family:var(--font-body);transition:all .2s}
.maya-send:hover{background:var(--teal-dark)}
.maya-send:disabled{background:var(--dim);cursor:not-allowed}
@keyframes td{0%,60%,100%{transform:translateY(0);opacity:.4}30%{transform:translateY(-5px);opacity:1}}
.typing{display:flex;gap:4px;padding:9px 12px}
.tdot{width:6px;height:6px;background:var(--teal);border-radius:50%;animation:td 1.2s infinite}
.tdot:nth-child(2){animation-delay:.2s}.tdot:nth-child(3){animation-delay:.4s}

/* PRO LOCK */
.pro-lock{background:linear-gradient(135deg,rgba(0,201,167,.06),rgba(255,179,71,.04));border:1px solid var(--teal-border);border-radius:12px;padding:20px;text-align:center}
.pro-lock h3{font-family:var(--font-head);font-size:18px;font-style:italic;margin-bottom:6px}
.pro-lock p{font-size:12px;color:var(--muted);margin-bottom:14px}
.btn-upgrade-lock{background:var(--teal);color:#060D16;border:none;border-radius:6px;padding:9px 22px;font-weight:700;font-size:13px;cursor:pointer;font-family:var(--font-body)}

/* LOADING */
.loading-screen{position:fixed;inset:0;background:var(--bg);display:flex;align-items:center;justify-content:center;z-index:100;flex-direction:column;gap:16px}
.loading-logo{font-family:var(--font-head);font-size:28px;font-style:italic}.loading-logo span{color:var(--teal)}

@media(max-width:900px){
  .sidebar{width:100%;height:auto;position:relative;flex-direction:row;flex-wrap:wrap}
  .main{margin-left:0;padding:16px}
  .stats-row{grid-template-columns:repeat(2,1fr)}
  .dash-grid{grid-template-columns:1fr}.card.full{grid-column:span 1}
}
</style>
</head>
<body>

<div class="loading-screen" id="loadingScreen">
  <div class="loading-logo"><i>Sum</i> <span>Goals</span></div>
  <div class="spinner"></div>
</div>

<div class="layout" id="appLayout" style="display:none">
  <div class="sidebar">
    <div class="sb-logo"><div class="logo"><i>Sum</i> <span>Goals</span></div></div>
    <div class="sb-user">
      <div class="sb-av" id="sbAv">R</div>
      <div>
        <div class="sb-name" id="sbName">Loading...</div>
        <span class="sb-plan free" id="sbPlan">Free</span>
      </div>
    </div>
    <div class="sb-nav">
      <div class="sb-section">Main</div>
      <button class="sb-link active" onclick="showSection('dashboard')">Dashboard</button>
      <button class="sb-link" onclick="showSection('maya')">Chat with Maya</button>
      <button class="sb-link" onclick="showSection('budget')">Budget Builder</button>
      <div class="sb-section">Track</div>
      <button class="sb-link" onclick="showSection('debt')">Debt Race</button>
      <button class="sb-link" onclick="showSection('goals')">My Goals</button>
      <button class="sb-link" onclick="showSection('score')">Health Score</button>
      <div class="sb-section">Premium</div>
      <button class="sb-link" onclick="showProFeature('transformation')">90-Day Plan</button>
      <button class="sb-link" onclick="showProFeature('mirror')">Money Mirror</button>
      <button class="sb-link" onclick="showProFeature('couples')">Couples Mode</button>
      <button class="sb-link" onclick="showProFeature('senior')">Senior Mode</button>
      <div class="sb-section">Support</div>
      <button class="sb-link" onclick="window.location.href='/support'">Help Center</button>
      <button class="sb-link" onclick="window.location.href='/settings'">Settings</button>
    </div>
    <div class="sb-bottom">
      <button class="btn-upgrade" id="sidebarUpgradeBtn" onclick="handleUpgrade('pro')" style="display:none">Upgrade to Pro — $9/mo</button>
      <button class="btn-signout" onclick="handleSignOut()">Sign out</button>
    </div>
  </div>

  <div class="main">
    <!-- DASHBOARD SECTION -->
    <div id="sec-dashboard">
      <div class="page-header">
        <div class="page-title">Good <span id="greeting">morning</span>, <span id="userName">there</span></div>
        <div class="page-sub" id="dayMessage">Here's your financial snapshot today.</div>
      </div>
      <div class="stats-row">
        <div class="stat-card highlight">
          <div class="sc-lbl">Health Score</div>
          <div class="sc-val teal" id="healthScore">—</div>
          <div class="sc-change up" id="scoreChange">Loading...</div>
        </div>
        <div class="stat-card">
          <div class="sc-lbl">Total Saved</div>
          <div class="sc-val green" id="totalSaved">$—</div>
          <div class="sc-change up">Keep it up</div>
        </div>
        <div class="stat-card">
          <div class="sc-lbl">Debt Remaining</div>
          <div class="sc-val red" id="totalDebt">$—</div>
          <div class="sc-change down">Paying it down</div>
        </div>
        <div class="stat-card">
          <div class="sc-lbl">Days to Payday</div>
          <div class="sc-val gold" id="daysToPayday">—</div>
          <div class="sc-change" id="dailyBudget">Set up payday</div>
        </div>
      </div>
      <div class="dash-grid">
        <div class="card">
          <div class="card-head"><div class="card-title">Financial Health Score</div><button class="card-action" onclick="showSection('score')">View details</button></div>
          <div class="score-display">
            <div class="score-circle"><div class="score-circle-val" id="scoreCircle">74</div></div>
            <div class="score-details">
              <div class="score-bar-row"><span class="score-bar-label">Budget</span><div class="score-bar-track"><div class="score-bar-fill" style="width:80%"></div></div><span class="score-bar-val">20</span></div>
              <div class="score-bar-row"><span class="score-bar-label">Debt</span><div class="score-bar-track"><div class="score-bar-fill" style="width:60%"></div></div><span class="score-bar-val">15</span></div>
              <div class="score-bar-row"><span class="score-bar-label">Savings</span><div class="score-bar-track"><div class="score-bar-fill" style="width:70%"></div></div><span class="score-bar-val">18</span></div>
              <div class="score-bar-row"><span class="score-bar-label">Emergency</span><div class="score-bar-track"><div class="score-bar-fill" style="width:84%"></div></div><span class="score-bar-val">21</span></div>
            </div>
          </div>
        </div>
        <div class="card">
          <div class="card-head"><div class="card-title">Payday Countdown</div><button class="card-action" onclick="setupPayday()">Update</button></div>
          <div class="payday-big">
            <div class="pd-label">Days until payday</div>
            <div class="pd-days-big" id="pdDaysBig">—</div>
            <div class="pd-budget" id="pdBudgetText">Tell Maya your payday date</div>
            <div class="pd-track"><div class="pd-fill" id="pdFill" style="width:0%"></div></div>
          </div>
        </div>
        <div class="card full">
          <div class="card-head"><div class="card-title">90-Day Financial Transformation</div><button class="card-action" onclick="showProFeature('transformation')">View program</button></div>
          <div class="transform-progress">
            <div class="tp-top"><div class="tp-day" id="tpDay">Day 0 of 90</div><div class="tp-pct" id="tpPct">0%</div></div>
            <div class="tp-track"><div class="tp-fill" id="tpFill" style="width:0%"></div></div>
          </div>
          <div class="tp-milestones">
            <div class="milestone" id="ms1"><div class="ms-check">○</div><div class="ms-title">Month 1 — Audit</div><div class="ms-sub">Foundation built</div></div>
            <div class="milestone" id="ms2"><div class="ms-check">○</div><div class="ms-title">Month 2 — Plan</div><div class="ms-sub">Systems in place</div></div>
            <div class="milestone" id="ms3"><div class="ms-check">○</div><div class="ms-title">Month 3 — Momentum</div><div class="ms-sub">Habits locked in</div></div>
          </div>
        </div>
      </div>

      <!-- MAYA QUICK CHAT ON DASHBOARD -->
      <div class="card" style="opacity:0;animation:up .5s ease .3s forwards">
        <div class="card-head"><div class="card-title">Ask Maya</div></div>
        <div class="maya-dash">
          <div class="maya-modes">
            <button class="mmode active" onclick="setDashMode('coach',this)">Coach</button>
            <button class="mmode" onclick="setDashMode('budget',this)">Budget</button>
            <button class="mmode" onclick="setDashMode('payday',this)">Payday</button>
            <button class="mmode" onclick="setDashMode('debt',this)">Debt Race</button>
            <button class="mmode" onclick="setDashMode('score',this)">Health Score</button>
            <button class="mmode" onclick="setDashMode('survival',this)">Survival</button>
          </div>
          <div class="maya-msgs" id="dashMsgs">
            <div class="mmrow bot"><div class="mm-sender">Maya</div><div class="mm-bub">Hey — I'm Maya, your Sum Goals coach. <strong>What do you need help with today?</strong> Tell me your currency and situation.</div></div>
          </div>
          <div class="maya-inp-row">
            <input class="maya-inp" id="dashInp" placeholder="Ask Maya anything..." onkeydown="if(event.key==='Enter'&&!event.shiftKey){event.preventDefault();sendDash()}">
            <button class="maya-send" id="dashSend" onclick="sendDash()">Send</button>
          </div>
        </div>
      </div>
    </div>

    <!-- OTHER SECTIONS (shown/hidden) -->
    <div id="sec-maya" style="display:none">
      <div class="page-header"><div class="page-title"><i>Chat with Maya</i></div><div class="page-sub">Your personal finance coach — available 24/7</div></div>
      <div class="card">
        <div class="maya-dash" style="height:500px">
          <div class="maya-modes">
            <button class="mmode active" onclick="setDashMode('coach',this)">Maya Coach</button>
            <button class="mmode" onclick="setDashMode('budget',this)">Budget Builder</button>
            <button class="mmode" onclick="setDashMode('payday',this)">Payday Countdown</button>
            <button class="mmode" onclick="setDashMode('debt',this)">Debt Race</button>
            <button class="mmode" onclick="setDashMode('score',this)">Health Score</button>
            <button class="mmode" onclick="setDashMode('personality',this)">Personality Quiz</button>
            <button class="mmode" onclick="setDashMode('hustle',this)">Side Hustle</button>
            <button class="mmode" onclick="setDashMode('emergency',this)">Emergency Kit</button>
            <button class="mmode" onclick="setDashMode('survival',this)">Survival Mode</button>
          </div>
          <div class="maya-msgs" id="dashMsgs2"></div>
          <div class="maya-inp-row">
            <input class="maya-inp" id="dashInp2" placeholder="Tell Maya your currency and situation..." onkeydown="if(event.key==='Enter'&&!event.shiftKey){event.preventDefault();sendDash2()}">
            <button class="maya-send" id="dashSend2" onclick="sendDash2()">Send</button>
          </div>
        </div>
      </div>
    </div>

    <div id="sec-budget" style="display:none">
      <div class="page-header"><div class="page-title"><i>Budget Builder</i></div><div class="page-sub">Build your complete monthly budget with Maya</div></div>
